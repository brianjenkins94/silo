{
  "name": "silo",
  "private": true,
  "type": "module",
  "description": "Earned, bounded trust for scripts — capability fingerprinting + a bundle-injected enforcing broker.",
  "bin": {
    "silo": "cli.ts"
  },
  "scripts": {
