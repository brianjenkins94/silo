    "@wakaru/cli": "^1.5.0",
    "@wakaru/unpacker": "^0.1.2",
    "esbuild": "0.28.1",
    "oxc-parser": "^0.137.0",
    "tsx": "4.22.4",
    "vite": "8.1.0",
    "vite-plugin-node-polyfills": "^0.28.0",
    "webcrack": "^2.16.0"
  }
